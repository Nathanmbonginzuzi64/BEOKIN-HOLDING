# Mot de passe admin pour publier/modifier/supprimer les infos
ADMIN_SECRET=changez-moi-en-production

# Token Vercel Blob (production Vercel uniquement, ou INFOS_STORAGE=blob en local)
BLOB_READ_WRITE_TOKEN=

# Stockage des infos : "local" | "blob" (optionnel — par défaut local en dev, blob sur Vercel)
# INFOS_STORAGE=local